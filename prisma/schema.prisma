generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum JobStatus {
  JOB_CREATED
  SCHEDULED
  IN_PROGRESS
  COMPLETED
  LOST
}

model Lead {
  id        Int      @id @default(autoincrement())

  firstName String
  lastName  String
  phone     String
  email     String?

  jobs      Job[]

  createdAt DateTime @default(now())
}

model Job {
  id          Int       @id @default(autoincrement())

  leadId      Int
  lead        Lead      @relation(fields: [leadId], references: [id])

  jobType     String
  leadSource  String
  description String?

  address     String
  city        String
  zip         String
  area        String

  startDate   String
  startTime   String
  endTime     String

  technician  String

  status      JobStatus @default(JOB_CREATED)

  events      EventLog[]

  createdAt   DateTime  @default(now())
}

model EventLog {
  id        Int      @id @default(autoincrement())

  jobId     Int
  job       Job      @relation(fields: [jobId], references: [id])

  type      String
  message   String

  createdAt DateTime @default(now())
}